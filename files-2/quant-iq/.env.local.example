# ─────────────────────────────────────────────────────────────────────────────
# Quant IQ — Environment Variables
# Copy this file to .env.local and fill in every value before running dev.
# Add all variables to Vercel: Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ⚠  Service role key BYPASSES Row Level Security. Never expose to the browser.

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# On Vercel, set to: https://your-app.vercel.app

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Cron authentication ───────────────────────────────────────────────────────
# Any random 32+ char secret. Generate: openssl rand -hex 32
# Sent as: Authorization: Bearer <value>
CRON_SECRET=replace_with_32_char_random_string

# ── Data sources ──────────────────────────────────────────────────────────────
# NewsAPI — newsapi.org/account (free dev: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here

# Polygon.io — polygon.io/dashboard (Starter plan: $29/mo for real-time)
# Leave blank during development — price data will show null until set
POLYGON_API_KEY=your_polygon_key_here

# ── Stripe ────────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret — from Stripe Dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create in Stripe Dashboard → Products → Add product
# Pro: $29/month recurring (14-day free trial)
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# Pro: $290/year recurring
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
# Advisor: $99/month recurring
STRIPE_ADVISOR_MONTHLY_PRICE_ID=price_...
# Advisor: $990/year recurring
STRIPE_ADVISOR_ANNUAL_PRICE_ID=price_...

# ─────────────────────────────────────────────────────────────────────────────
# SETUP CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────
# 1. npm install
# 2. cp .env.local.example .env.local  →  fill in Supabase + Anthropic + CRON_SECRET
# 3. supabase db push  (runs both SQL migrations)
# 4. npm run dev
# 5. Test cron manually: npm run cron:ingest  then  npm run cron:themes
# 6. Deploy: git push origin main  (Vercel auto-deploys)
# 7. Add all env vars to Vercel dashboard
# 8. Set Supabase auth redirect: Authentication → URL Config → add Vercel URL
# 9. Create Stripe products, add price IDs, set up webhook endpoint
# ─────────────────────────────────────────────────────────────────────────────
